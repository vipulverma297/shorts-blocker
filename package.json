{
  "name": "ShortsBlockerReactNative",
  "version": "1.0.0",
  "description": "Cross-platform app to block addictive short-video content",
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "xcodebuild -workspace ios/ShortsBlockerReactNative.xcworkspace -scheme ShortsBlockerReactNative -configuration Release -destination generic/platform=iOS -archivePath ios/build/ShortsBlockerReactNative.xcarchive archive"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.72.6",
    "react-native-device-info": "^10.11.0",
    "react-native-permissions": "^3.9.3",
    "@react-native-async-storage/async-storage": "^1.19.3",
    "react-native-background-job": "^0.2.8"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@tsconfig/react-native": "^3.0.0",
    "@types/react": "^18.0.24",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^2.4.1",
    "react-test-renderer": "18.2.0",
    "typescript": "4.8.4"
  },
  "jest": {
    "preset": "react-native"
  },
  "keywords": [
    "react-native",
    "shorts-blocker",
    "addiction-prevention",
    "cross-platform"
  ],
  "author": "Shorts Blocker Team",
  "license": "MIT"
}
